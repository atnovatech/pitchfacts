{
  "rewrites": [{ "source": "/(.*)", "destination": "/" }],
  "crons": [
    { "path": "/api/cron/update?task=daily", "schedule": "0 0 * * *" },
    { "path": "/api/cron/update?task=live", "schedule": "0 1 * * *" },
    { "path": "/api/cron/update?task=weekly", "schedule": "0 0 * * 4" },
    { "path": "/api/cron/update?task=standings", "schedule": "0 1 * * 0" },
    { "path": "/api/cron/update?task=team-forms", "schedule": "0 3 * * *" }
  ]
}